# PostgreSQL connection string used by Prisma.
# For local dev, spin up Postgres (e.g. `docker run --name helia-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres`)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/helia?schema=public"

# Secret used to sign session cookies. Generate with: openssl rand -base64 32
APP_SECRET="change-me-to-a-long-random-string"
