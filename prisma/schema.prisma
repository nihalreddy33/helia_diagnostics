// Helia Diagnostics — Prisma schema
// PostgreSQL-backed text reporting platform.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RADIOLOGIST
  RECEPTION
}

enum Modality {
  XRAY
  CT
  MRI
  USG
}

enum ReportStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      Role
  createdAt DateTime @default(now())

  // Reports authored by this user when acting as a radiologist.
  reports Report[] @relation("RadiologistReports")

  @@index([role])
}

model Patient {
  id        String   @id @default(cuid())
  uhid      String   @unique // Unique Hospital ID
  name      String
  age       Int
  gender    String
  createdAt DateTime @default(now())

  // Reception assigns the scan type the patient is here for. The radiologist
  // uses this to filter the relevant report templates. (Pragmatic extension
  // of the core spec so the intake form's "target modality" has a home.)
  targetModality Modality?

  reports Report[]
}

model Template {
  id                String   @id @default(cuid())
  title             String
  modality          Modality
  defaultFindings   String
  defaultImpression String
  createdAt         DateTime @default(now())

  reports Report[]

  @@index([modality])
}

model Report {
  id         String       @id @default(cuid())
  status     ReportStatus @default(DRAFT)
  findings   String
  impression String

  // Denormalized "YYYY-MM" bucket for fast month-wise archive grouping.
  createdMonthYear String

  createdAt  DateTime  @default(now())
  approvedAt DateTime?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  radiologistId String?
  radiologist   User?   @relation("RadiologistReports", fields: [radiologistId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdMonthYear])
  @@index([patientId])
}
