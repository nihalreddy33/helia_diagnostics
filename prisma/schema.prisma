// Helia Diagnostics — Prisma schema
// PostgreSQL-backed text reporting platform with role-based access control.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECEPTIONIST
  RADIOLOGIST
}

enum Modality {
  XRAY
  CT
  MRI
  USG
}

enum ReportStatus {
  DRAFT
  APPROVED
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  // Reports authored by this user when acting as a radiologist.
  reports Report[] @relation("RadiologistReports")

  @@index([role])
}

model Patient {
  id        String   @id @default(uuid()) @db.Uuid
  uhid      String   @unique // Structured hospital id, e.g. HELIA-1001
  name      String
  age       Int
  gender    String
  createdAt DateTime @default(now())

  reports Report[]
}

model Template {
  id                String   @id @default(uuid()) @db.Uuid
  title             String   @unique
  modality          Modality
  defaultFindings   String   @db.Text
  defaultImpression String   @db.Text
  createdAt         DateTime @default(now())

  reports Report[]

  @@index([modality])
}

model Report {
  id         String       @id @default(uuid()) @db.Uuid
  status     ReportStatus @default(DRAFT)
  findings   String       @db.Text
  impression String       @db.Text

  // Denormalized "YYYY-MM" bucket for fast month-wise grouping.
  createdMonthYear String

  createdAt  DateTime  @default(now())
  approvedAt DateTime?

  patientId String  @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  templateId String?   @db.Uuid
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  radiologistId String? @db.Uuid
  radiologist   User?   @relation("RadiologistReports", fields: [radiologistId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdMonthYear])
  @@index([patientId])
}
