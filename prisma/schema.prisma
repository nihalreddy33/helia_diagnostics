// Helia Diagnostics — Prisma schema
// PostgreSQL-backed text reporting platform with role-based access control.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECEPTIONIST
  RADIOLOGIST
  LAB_TECHNICIAN
}

enum Department {
  RADIOLOGY
  LAB
  OTHER
}

enum LabFlag {
  NORMAL
  HIGH
  LOW
}

enum Modality {
  XRAY
  CT
  MRI
  USG
}

enum ReportStatus {
  DRAFT
  APPROVED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  // Reports authored by this user when acting as a radiologist.
  reports Report[] @relation("RadiologistReports")
  // Lab reports authored by this user when acting as a lab technician.
  labReports LabReport[] @relation("LabReports")
  // Bills raised by this user when acting as a receptionist.
  bills   Bill[]   @relation("BillsRaised")
  // Reports this user handed to patients (reception delivery tracking).
  reportsDelivered    Report[]    @relation("ReportsDelivered")
  labReportsDelivered LabReport[] @relation("LabReportsDelivered")
  // Audit-trail entries for this user.
  activityLogs ActivityLog[]

  @@index([role])
}

// Curated list of referring doctors for billing autocomplete. The bill stores
// the name as free text, so this is purely a suggestion list.
model ReferringDoctor {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active])
}

// Audit trail of user activity (logins, key actions). Name/role are snapshotted
// so the log survives even if the user is later deleted.
model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName  String
  userRole  Role
  action    String // e.g. LOGIN, LOGOUT, BILL_CREATED
  detail    String   @default("")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Patient {
  id        String   @id @default(uuid()) @db.Uuid
  uhid      String   @unique // Structured hospital id, e.g. HELIA-1001
  name      String
  age       Int
  gender    String
  mobile    String   @default("")
  createdAt DateTime @default(now())

  reports    Report[]
  labReports LabReport[]
  bills      Bill[]
}

model Template {
  id                String   @id @default(uuid()) @db.Uuid
  title             String   @unique
  modality          Modality
  defaultFindings   String   @db.Text
  defaultImpression String   @db.Text
  // Optional declaration / note block (e.g. PCPNDT declaration on obstetric
  // scans). May contain a {{radiologist}} token, substituted at print time.
  defaultFooter     String   @db.Text @default("")
  createdAt         DateTime @default(now())

  reports Report[]

  @@index([modality])
}

model Report {
  id         String       @id @default(uuid()) @db.Uuid
  status     ReportStatus @default(DRAFT)
  findings   String       @db.Text
  impression String       @db.Text
  // Snapshot of the declaration / footer for this report (may be empty).
  footer     String       @db.Text @default("")

  // Denormalized "YYYY-MM" bucket for fast month-wise grouping.
  createdMonthYear String

  createdAt  DateTime  @default(now())
  approvedAt DateTime?
  // When the printed report was handed to the patient, and by whom.
  deliveredAt   DateTime?
  deliveredById String?   @db.Uuid
  deliveredBy   User?     @relation("ReportsDelivered", fields: [deliveredById], references: [id], onDelete: SetNull)

  patientId String  @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  templateId String?   @db.Uuid
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  radiologistId String? @db.Uuid
  radiologist   User?   @relation("RadiologistReports", fields: [radiologistId], references: [id], onDelete: SetNull)

  // The bill line that ordered this scan (when created from billing).
  billItem BillItem?

  @@index([status])
  @@index([createdMonthYear])
  @@index([patientId])
}

// --- Billing -----------------------------------------------------------------

// All monetary amounts are stored as integer paise (₹1 = 100) to stay exact.
model Service {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique
  // Routing: RADIOLOGY → creates a scan report (radiologist worklist),
  // LAB → creates a lab report (lab technician worklist), OTHER → no report.
  department Department @default(OTHER)
  // Scan type, only meaningful for RADIOLOGY services.
  modality   Modality?
  price      Int // paise
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())

  billItems BillItem[]

  @@index([active])
  @@index([department])
}

model Bill {
  id        String @id @default(uuid()) @db.Uuid
  invoiceNo String @unique // e.g. HELIA-INV-1001

  patientId String  @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  receptionistId String? @db.Uuid
  receptionist   User?   @relation("BillsRaised", fields: [receptionistId], references: [id], onDelete: SetNull)

  // Doctor who referred the patient for these tests.
  referringDoctor String @default("")

  subtotal      Int            @default(0) // paise, before discount
  discount      Int            @default(0) // paise
  total         Int            @default(0) // paise, subtotal - discount
  amountPaid    Int            @default(0) // paise
  paymentMethod PaymentMethod?
  status        PaymentStatus  @default(UNPAID)

  createdMonthYear String
  createdAt        DateTime @default(now())

  items BillItem[]

  @@index([createdMonthYear])
  @@index([patientId])
  @@index([status])
}

model BillItem {
  id     String @id @default(uuid()) @db.Uuid
  billId String @db.Uuid
  bill   Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)

  serviceId String?  @db.Uuid
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  description String // snapshot of the service name at billing time
  quantity   Int    @default(1)
  unitPrice  Int // paise
  amount     Int // paise (quantity * unitPrice)

  // The scan order created for this line, if the service is a radiology scan.
  reportId String? @unique @db.Uuid
  report   Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  // The lab order created for this line, if the service is a lab test.
  labReportId String?    @unique @db.Uuid
  labReport   LabReport? @relation(fields: [labReportId], references: [id], onDelete: SetNull)

  @@index([billId])
}

// --- Lab / Pathology ---------------------------------------------------------

// A reusable lab test format (e.g. "Complete Blood Count") whose parameters are
// injected as result rows when the technician picks it.
model LabTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @unique
  createdAt DateTime @default(now())

  parameters LabTemplateParameter[]
  reports    LabReport[]
}

model LabTemplateParameter {
  id         String      @id @default(uuid()) @db.Uuid
  templateId String      @db.Uuid
  template   LabTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  name           String
  unit           String @default("")
  referenceRange String @default("")
  position       Int    @default(0)

  @@index([templateId])
}

model LabReport {
  id     String       @id @default(uuid()) @db.Uuid
  status ReportStatus @default(DRAFT)

  createdMonthYear String
  createdAt        DateTime  @default(now())
  approvedAt       DateTime?
  // When the printed report was handed to the patient, and by whom.
  deliveredAt      DateTime?
  deliveredById    String?   @db.Uuid
  deliveredBy      User?     @relation("LabReportsDelivered", fields: [deliveredById], references: [id], onDelete: SetNull)

  patientId String  @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  templateId String?      @db.Uuid
  template   LabTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  technicianId String? @db.Uuid
  technician   User?   @relation("LabReports", fields: [technicianId], references: [id], onDelete: SetNull)

  results  LabResult[]
  billItem BillItem?

  @@index([status])
  @@index([patientId])
  @@index([createdMonthYear])
}

model LabResult {
  id       String    @id @default(uuid()) @db.Uuid
  reportId String    @db.Uuid
  report   LabReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  name           String
  value          String  @default("")
  unit           String  @default("")
  referenceRange String  @default("")
  flag           LabFlag @default(NORMAL)
  position       Int     @default(0)

  @@index([reportId])
}
